class TablaHash:

    def __init__(self, tamaño=10):
        self.tamaño = tamaño
        self.tabla = [[] for _ in range(tamaño)]
        self.elementos = 0

    # función hash
    def funcion_hash(self, clave):
        return hash(clave) % self.tamaño

    # insertar registro
    def insertar(self, id_estudiante, nombre):

        indice = self.funcion_hash(id_estudiante)

        for registro in self.tabla[indice]:
            if registro[0] == id_estudiante:
                registro[1] = nombre
                return

        self.tabla[indice].append([id_estudiante, nombre])
        self.elementos += 1

    # buscar
    def buscar(self, id_estudiante):

        indice = self.funcion_hash(id_estudiante)

        for registro in self.tabla[indice]:
            if registro[0] == id_estudiante:
                return registro

        return None

    # eliminar
    def eliminar(self, id_estudiante):

        indice = self.funcion_hash(id_estudiante)

        for i, registro in enumerate(self.tabla[indice]):
            if registro[0] == id_estudiante:
                self.tabla[indice].pop(i)
                self.elementos -= 1
                return True

        return False

    # factor de carga
    def factor_carga(self):
        return self.elementos / self.tamaño


tabla = TablaHash()

tabla.insertar(101, "Ana")
tabla.insertar(102, "Carlos")
tabla.insertar(103, "Maria")

print("Buscar:", tabla.buscar(102))
tabla.eliminar(102)

print("Factor de carga:", tabla.factor_carga())
